## Kali Linux Audit Rules
## Adapted from IppSec/parrot-build — Kali-compatible, no Parrot dependencies

## Buffer size — increase if audit logs show "(backlog limit exceeded)"
-b 8192

## Failure mode: 1 = printk (log), 2 = panic
-f 1

## ─── Self-auditing ──────────────────────────────────────────────────────────
## Track changes to audit configuration itself
-w /etc/audit/ -p wa -k audit_config
-w /etc/audit/rules.d/ -p wa -k audit_config
-w /etc/libaudit.conf -p wa -k audit_config
-w /etc/audisp/ -p wa -k audit_config
-w /var/log/audit/ -p wa -k audit_logs

## ─── System integrity ───────────────────────────────────────────────────────
## Kernel module loading/unloading
-w /sbin/insmod -p x -k modules
-w /sbin/rmmod -p x -k modules
-w /sbin/modprobe -p x -k modules
-a always,exit -F arch=b64 -S init_module,finit_module,delete_module -k modules

## Mount operations
-a always,exit -F arch=b64 -S mount,umount2 -k mount

## ─── User and group changes ─────────────────────────────────────────────────
-w /etc/group -p wa -k identity
-w /etc/passwd -p wa -k identity
-w /etc/gshadow -p wa -k identity
-w /etc/shadow -p wa -k identity
-w /etc/security/opasswd -p wa -k identity
-w /usr/sbin/useradd -p x -k user_mgmt
-w /usr/sbin/usermod -p x -k user_mgmt
-w /usr/sbin/userdel -p x -k user_mgmt
-w /usr/sbin/groupadd -p x -k user_mgmt
-w /usr/sbin/groupmod -p x -k user_mgmt
-w /usr/sbin/groupdel -p x -k user_mgmt

## ─── Privilege escalation ───────────────────────────────────────────────────
-w /etc/sudoers -p wa -k sudoers
-w /etc/sudoers.d/ -p wa -k sudoers
-w /usr/bin/sudo -p x -k sudo
-w /usr/bin/su -p x -k su
-a always,exit -F arch=b64 -S setuid,setgid,setreuid,setregid -k setuid

## ─── SSH configuration ──────────────────────────────────────────────────────
-w /etc/ssh/sshd_config -p wa -k sshd
-w /etc/ssh/ssh_config -p wa -k ssh_config

## ─── Crontab ────────────────────────────────────────────────────────────────
-w /etc/cron.allow -p wa -k cron
-w /etc/cron.deny -p wa -k cron
-w /etc/cron.d/ -p wa -k cron
-w /etc/cron.daily/ -p wa -k cron
-w /etc/cron.hourly/ -p wa -k cron
-w /etc/cron.monthly/ -p wa -k cron
-w /etc/cron.weekly/ -p wa -k cron
-w /etc/crontab -p wa -k cron
-w /var/spool/cron/ -p wa -k cron
-w /usr/bin/crontab -p x -k cron

## ─── Suspicious binaries (OPSEC: watching attacker tools too) ───────────────
-w /usr/bin/wget -p x -k download
-w /usr/bin/curl -p x -k download
-w /usr/bin/base64 -p x -k encoding
-w /usr/bin/nc -p x -k netcat
-w /usr/bin/ncat -p x -k netcat
-w /usr/bin/netcat -p x -k netcat
-w /bin/nc -p x -k netcat
-w /usr/bin/ssh -p x -k ssh_exec
-w /usr/bin/python3 -p x -k interpreter
-w /usr/bin/python -p x -k interpreter
-w /usr/bin/perl -p x -k interpreter
-w /usr/bin/ruby -p x -k interpreter
-w /usr/bin/php -p x -k interpreter

## Compression tools (data exfil indicator)
-w /usr/bin/zip -p x -k compression
-w /usr/bin/tar -p x -k compression
-w /usr/bin/gzip -p x -k compression
-w /usr/bin/bzip2 -p x -k compression
-w /usr/bin/7z -p x -k compression

## ─── Code injection / process manipulation ──────────────────────────────────
-a always,exit -F arch=b64 -S ptrace -k code_injection
-a always,exit -F arch=b64 -S process_vm_readv,process_vm_writev -k code_injection

## Fileless execution (memfd_create — malware living in memory)
-a always,exit -F arch=b64 -S memfd_create -k fileless_exec

## ─── Package managers ───────────────────────────────────────────────────────
-w /usr/bin/apt -p x -k pkg_mgmt
-w /usr/bin/apt-get -p x -k pkg_mgmt
-w /usr/bin/dpkg -p x -k pkg_mgmt
-w /usr/bin/pip -p x -k pkg_mgmt
-w /usr/bin/pip3 -p x -k pkg_mgmt
-w /usr/bin/pipx -p x -k pkg_mgmt
-w /usr/bin/gem -p x -k pkg_mgmt
-w /usr/local/bin/pipx -p x -k pkg_mgmt

## ─── Container tools ────────────────────────────────────────────────────────
-w /usr/bin/docker -p x -k container
-w /usr/bin/podman -p x -k container

## ─── CVE-specific rules ─────────────────────────────────────────────────────
## CVE-2021-3560 (polkit privilege escalation)
-w /usr/bin/pkexec -p x -k CVE-2021-3560

## CVE-2021-4034 (polkit pkexec local privesc)
-a always,exit -F arch=b64 -S execve -F path=/usr/bin/pkexec -k CVE-2021-4034

## ─── Reconnaissance indicators ──────────────────────────────────────────────
## Reads of /etc/passwd and /etc/shadow by non-root
-a always,exit -F arch=b64 -S open,openat -F path=/etc/passwd -F auid>=1000 -k recon_passwd
-a always,exit -F arch=b64 -S open,openat -F path=/etc/shadow -F auid>=1000 -k recon_shadow

## ─── Immutable flag (must be last) ─────────────────────────────────────────
## Uncomment to make rules immutable until reboot (prevents tampering at runtime)
## Requires reboot to change rules after enabling.
#-e 2
